{
  "location_id": "bedroom-test",

  "cameras": {
    "cam0_id": 0,
    "cam2_id": 2,
    "width": 640,
    "height": 480
  },

  "roi": {
    "cam0_path": "config/roi_cam0.json",
    "cam2_path": "config/roi_cam2.json"
  },

  "yolo": {
    "model_path": "yolov8n.pt",
    "conf": 0.35,
    "person_class_id": 0
  },

  "decision": {
    "unsafe_on_count": 3,
    "safe_on_count": 5
  },

  "fusion": {
    "confirm_window_s": 0.7,
    "handoff_window_s": 0.7,
    "end_after_s": 2.0,
    "cooldown_s": 5.0
  },

  "alarm": {
    "enabled": true,
    "cooldown_s": 5.0
  },

  "firebase": {
    "enabled": true,
    "service_account_path": "config/firebase_service_account.json",
    "collection": "events"
  },

  "ui": {
    "show_windows": true,
    "draw_roi": true,
    "show_fusion_overlay": true
  }
}
